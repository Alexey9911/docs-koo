{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Neyrs",
  "logo": {
    "light": "/logo/dark.svg",
    "dark": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#1a1a1a",
    "light": "#404040",
    "dark": "#000000"
  },
  "anchors": {
    "from": "#1a1a1a",
    "to": "#ffffff"
  },
  "appearance": {
    "default": "dark"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/Neyrspmnd/neyrs-repo"
        },
        {
          "anchor": "Twitter",
          "icon": "x-twitter",
          "href": "https://x.com/NeyrsAgent"
        },
        {
          "anchor": "Telegram",
          "icon": "telegram",
          "href": "https://t.me/NeyrsDeFI"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "GETTING STARTED",
            "icon": "rocket",
            "pages": [
              "index",
              "introduction/quickstart",
              "introduction/architecture"
            ]
          },
          {
            "group": "CORE CAPABILITIES",
            "icon": "wand-magic-sparkles",
            "pages": [
              "core-features/natural-language",
              "core-features/wallet-operations",
              "core-features/defi-integration",
              "core-features/commerce-payments"
            ]
          },
          {
            "group": "INTEGRATIONS",
            "icon": "plug",
            "pages": [
              "integrations/solana",
              "integrations/wallet-security",
              "integrations/transaction-simulation"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Introduction",
            "icon": "book",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Chat Operations",
            "icon": "messages",
            "pages": [
              "api-reference/sessions/create-session",
              "api-reference/sessions/get-session",
              "api-reference/sessions/delete-session"
            ]
          },
          {
            "group": "Messages",
            "icon": "comment",
            "pages": [
              "api-reference/messages/send-message",
              "api-reference/messages/get-history"
            ]
          },
          {
            "group": "Wallet & Portfolio",
            "icon": "wallet",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create"
            ]
          },
          {
            "group": "Analytics",
            "icon": "chart-simple",
            "pages": [
              "api-reference/analytics/get-metrics",
              "api-reference/analytics/get-usage"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Try Neyrs",
      "href": "https://docs.neyrs.cloud"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/NeyrsAgent",
      "github": "https://github.com/Neyrspmnd/neyrs-repo",
      "telegram": "https://t.me/NeyrsDeFI",
      "website": "https://docs.neyrs.cloud"
    }
  }
}
